      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./task": {
      "types": "./dist/task/Task.d.ts",
      "import": "./dist/task/Task.js"
    },
    "./task-service": {
      "types": "./dist/task/TaskService.d.ts",
      "import": "./dist/task/TaskService.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
