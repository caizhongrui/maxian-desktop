  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cache": "^4.1.3",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "maxian",
    "ai",
    "agent",
    "coding"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "get-folder-size": "^5.0.0",
    "ignore": "^7.0.5",
    "node-cache": "^5.1.2",
    "proper-lockfile": "^4.1.2",
    "stream-json": "^2.1.0",
    "zod": "^4.3.6"
  }
