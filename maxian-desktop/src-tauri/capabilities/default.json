{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认能力：允许前端调用 dialog/shell/http 插件及 invoke 命令",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "bin/maxian-server", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        { "name": "bin/maxian-server", "sidecar": true }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:*" },
        { "url": "http://localhost:*" },
        { "url": "http://*:*" },
        { "url": "http://*" },
        { "url": "https://*:*" },
        { "url": "https://*" }
      ]
    },
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    "fs:allow-exists"
  ]
}
