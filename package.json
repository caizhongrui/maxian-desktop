{
  "name": "maxian-monorepo",
  "version": "0.1.0",
  "description": "码弦（Maxian）AI 开发平台 Monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@tailwindcss/oxide", "esbuild", "sharp"]
  },
  "scripts": {
    "build:core": "pnpm --filter @maxian/core run build",
    "build:server": "pnpm --filter @maxian/server run build",
    "build:sdk": "pnpm --filter @maxian/sdk run build",
    "build:all": "pnpm run build:core && pnpm run build:sdk && pnpm run build:server",
    "typecheck": "pnpm -r typecheck"
  }
}
